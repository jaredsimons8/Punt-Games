# Local credentials for running migrations and scripts manually.
# Copy this file to scripts/.env.local and fill in your values.
# .env.local is gitignored — never commit it.

# Supabase service role key (same one used in GitHub Actions secrets).
# Dashboard → Project → Settings → API → service_role key
SUPABASE_URL=https://pjbnsonfojyzbjjawpxu.supabase.co
SUPABASE_SERVICE_KEY=

# Personal access token for the Supabase Management API (runs DDL migrations).
# Dashboard → supabase.com/dashboard/account/tokens → Generate new token
SUPABASE_ACCESS_TOKEN=
